# ============================================================
# BACKEND .env.example — copia a app/.env y completa los valores
# ============================================================
# SECRETOS: nunca subir a git. Nunca exponer al frontend.

# --- LLM ---
# Requerido si LLM_PROVIDER=openai. Obtén tu key en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# --- Embeddings ---
# openai → usa OPENAI_API_KEY. hf → local, descarga modelo en primer uso (no requiere key).
EMBED_PROVIDER=openai
# Si EMBED_PROVIDER=openai: text-embedding-3-small | text-embedding-3-large
# Si EMBED_PROVIDER=hf:     BAAI/bge-m3 | intfloat/multilingual-e5-large
EMBED_MODEL=text-embedding-3-small

# --- Vector store ---
CHROMA_PERSIST_DIR=./app/data/chroma

# --- App ---
DEBUG=True
CORS_ORIGIN=http://localhost:5173
